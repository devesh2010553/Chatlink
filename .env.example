# MongoDB connection string (use MongoDB Atlas free tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatroulette?retryWrites=true&w=majority

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Port (Render sets this automatically)
PORT=3000

# Secret for admin sessions
ADMIN_SECRET=your_random_secret_string_here
